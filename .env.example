# =========================================================================
# MOCK MODE — flip this on to run the app with no external services.
# When enabled:
#   - MongoDB is bypassed (in-memory store, resets on server restart)
#   - Google Calendar is bypassed (fake events including one firing in 3 min)
#   - Google OAuth login is bypassed
# Useful for local demos and UI work. Do NOT enable in production.
# =========================================================================
NUXT_MOCK_MODE=1
NUXT_PUBLIC_MOCK_MODE=1

# Set MOCK_MODE=0 (or remove the lines above) to run with real services. Then:

# MongoDB Atlas connection string
NUXT_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dashboard?retryWrites=true&w=majority

# Google Cloud OAuth client (Web application)
# Authorized redirect URI in GCP must exactly match NUXT_GOOGLE_REDIRECT_URI below
# Scopes required: openid, email, profile, calendar.readonly
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/callback

# HMAC key used to sign session cookies. Any random long string (>= 32 chars).
NUXT_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

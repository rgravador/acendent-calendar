# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dashboard?retryWrites=true&w=majority

# Google Cloud OAuth client (Web application)
# Authorized redirect URI in GCP must exactly match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/setup/callback

# Secret that must appear as ?secret=... to access /setup. Any random long string.
SETUP_SECRET=change-me

# Password you type into /login to access the dashboard.
DASHBOARD_PASSWORD=change-me

# HMAC key used to sign session cookies. Any random long string (>= 32 chars).
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
